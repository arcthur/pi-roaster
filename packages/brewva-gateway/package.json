{
  "name": "@brewva/brewva-gateway",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime-plugins": {
      "types": "./dist/runtime-plugins.d.ts",
      "bun": "./src/runtime-plugins.ts",
      "import": "./dist/runtime-plugins.js",
      "default": "./dist/runtime-plugins.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "bun": "./src/host.ts",
      "import": "./dist/host.js",
      "default": "./dist/host.js"
    }
  },
  "dependencies": {
    "@brewva/brewva-addons": "workspace:*",
    "@brewva/brewva-channels-telegram": "workspace:*",
    "@brewva/brewva-ingress": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-skill-broker": "workspace:*",
    "@brewva/brewva-tools": "workspace:*",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.48",
    "ajv": "^8.18.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
